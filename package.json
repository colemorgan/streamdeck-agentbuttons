{
  "name": "streamdeck-agentbuttons",
  "private": true,
  "version": "1.0.0",
  "description": "Stream Deck Marketplace plugin + macOS companion for ChatGPT Codex agent status keys",
  "repository": {
    "type": "git",
    "url": "https://github.com/colemorgan/streamdeck-agentbuttons.git"
  },
  "keywords": [
    "streamdeck",
    "elgato",
    "plugin",
    "chatgpt",
    "codex",
    "macos"
  ],
  "workspaces": [
    "packages/*",
    "companion",
    "plugin"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test:protocol": "npm run test -w @agentbuttons/protocol",
    "companion": "npm run build -w @agentbuttons/protocol && npm run build -w @agentbuttons/companion && node companion/dist/cli.js",
    "companion:app": "bash companion/scripts/build-macos-app.sh",
    "plugin:build": "npm run build -w @agentbuttons/plugin",
    "plugin:pack": "bash plugin/scripts/pack-release.sh",
    "plugin:icons": "bash plugin/scripts/generate-icons.sh",
    "release:local": "npm test && npm run companion:app && npm run plugin:pack"
  },
  "engines": {
    "node": ">=20.5.1"
  },
  "license": "MIT"
}
